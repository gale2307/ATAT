# API Keys
QWEN_MT_API_KEY=your_qwen_mt_api_key_here
OPENAI_API_KEY=                          # optional, for GPT-4o translation

# Redis
REDIS_URL=redis://localhost:6379

# Storage (local path for temp files)
STORAGE_PATH=/tmp/atat

# GPU workers
RUNPOD_API_KEY=your_runpod_api_key_here
STT_WORKER_URL=https://api.runpod.ai/v2/YOUR_STT_ENDPOINT/run
TRANSLATION_WORKER_URL=https://api.runpod.ai/v2/YOUR_TRANSLATION_ENDPOINT/run

# HuggingFace (for pulling LoRA checkpoints)
HF_TOKEN=your_hf_token_here
HF_STT_MODEL_REPO=your-username/whisper-large-v3-lol-lora

# Backend settings
DEBUG=false
CORS_ORIGINS=http://localhost:3000
